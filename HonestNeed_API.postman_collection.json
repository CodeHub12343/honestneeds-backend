          "name": "List Campaigns (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/campaigns?page=1&limit=20&type=fundraising",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "campaigns"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "type",
                  "value": "fundraising"
                }
              ]
