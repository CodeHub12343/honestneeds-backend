              "raw": "{\n  \"title\": \"Community Garden Initiative\",\n  \"description\": \"Help us build a community garden in our neighborhood\",\n  \"campaign_type\": \"fundraising\",\n  \"goal_amount\": 500000,\n  \"category\": \"Community\",\n  \"tags\": [\"community\", \"gardening\", \"local\"],\n  \"start_date\": \"2026-04-10T00:00:00Z\",\n  \"end_date\": \"2026-06-08T23:59:59Z\",\n  \"location\": {\n    \"city\": \"San Francisco\",\n    \"state\": \"CA\",\n    \"latitude\": 37.7749,\n    \"longitude\": -122.4194\n  }\n}"
            }
          }
        },
