{
  "name": "honestneed-backend",
  "version": "1.0.0",
  "description": "HonestNeed Platform - Backend API (Node.js + Express + MongoDB)",
  "main": "src/app.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "nodemon --exec node src/app.js",
    "start": "node src/app.js",
    "build": "echo 'Build step - no compilation needed for Node.js'",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest tests/integration",
    "test:unit": "jest tests/unit",
    "lint": "eslint src tests --max-warnings 0",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"./*.js\" \"./*.json\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/resetDb.js",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:rollback": "node scripts/migrationRollback.js",
    "generate:keys": "node scripts/generateKeys.js",
    "prepare": "husky install",
    "test:day5": "jest tests/day5-integration-testing.test.js --detectOpenHandles --verbose",
    "test:day5:watch": "jest tests/day5-integration-testing.test.js --watch --verbose",
    "test:day5:coverage": "jest tests/day5-integration-testing.test.js --coverage",
    "test:workflow": "jest tests/day5-integration-testing.test.js -t 'Full Campaign Workflow' --verbose",
    "test:errors": "jest tests/day5-integration-testing.test.js -t 'Error Scenario' --verbose",
    "test:edge": "jest tests/day5-integration-testing.test.js -t 'Edge Case' --verbose",
    "test:perf": "jest tests/day5-integration-testing.test.js -t 'Performance' --verbose",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:day5",
    "test:all:coverage": "jest --coverage tests/",
    "test:benchmark": "node tests/benchmarks.js",
    "test:report": "node scripts/generateTestReport.js",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --detectOpenHandles"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.1.0",
    "joi": "^18.1.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "node-cron": "^3.0.3",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.10.1",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^4.3.1",
    "stripe": "^22.0.0",
    "twilio": "^5.13.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "eslint": "^8.54.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "faker": "^6.6.6",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.6",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/honestneed-backend.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/honestneed-backend/issues"
  },
  "keywords": [
    "honestneed",
    "crowdfunding",
    "campaigns",
    "sharing",
    "api"
  ],
  "author": "Santiago Rueda & Team",
  "license": "MIT"
}
