# Environment Configuration
NODE_ENV=development

# API Configuration
API_PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/honestneed-dev
MONGODB_DB=honestneed-dev

# JWT & Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRY=365d
REFRESH_TOKEN_EXPIRY=30d
JWT_ALGORITHM=HS256

# Security
BCRYPT_ROUNDS=10
ENCRYPTION_KEY=your-encryption-key-32-chars-exactly

# Email Service (SendGrid)
SENDGRID_API_KEY=SG.your-sendgrid-key-here
SENDGRID_FROM_EMAIL=noreply@honestneed.com

# AWS (S3 for assets, CloudWatch for monitoring)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=honestneed-assets
S3_REGION=us-east-1

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags (Phase 2+)
FEATURE_PAID_SHARING=true
FEATURE_SWEEPSTAKES=true
FEATURE_QR_TRACKING=true

# External APIs (Phase 2+)
STRIPE_API_KEY=sk_test_your-stripe-key
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret

# Admin Configuration
ADMIN_EMAIL=admin@honestneed.com
SUPPORT_EMAIL=support@honestneed.com

# Monitoring & Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Seed Data (for development)
SEED_DATA_COUNT=50
